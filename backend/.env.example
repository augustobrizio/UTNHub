DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require&channel_binding=require
ENVIRONMENT=dev

# --- Clasificador IA de novedades (OpenAI) ---
OPENAI_API_KEY=
# gpt-4o-mini (default) | gpt-4.1-mini | gpt-4.1-nano
NOVEDADES_LLM_MODEL=gpt-4o-mini
# Confianza minima para autopublicar; por debajo queda pendiente de moderacion
NOVEDADES_UMBRAL_PUBLICAR=0.75
# Tope de items clasificados por corrida (control de costos)
NOVEDADES_MAX_ITEMS_POR_CORRIDA=40

# --- Fuente: Instagram (cuenta bot dedicada) ---
# Recomendado: sessionid de un browser logueado (evita login/challenge/IP-block).
# DevTools > Application > Cookies > instagram.com > sessionid
INSTAGRAM_SESSIONID=
# Fallback (fragil): login por usuario/password.
INSTAGRAM_USUARIO=
INSTAGRAM_PASSWORD=
INSTAGRAM_SESSION_PATH=/data/instagram_session.json
# Handles de centros de estudiantes separados por coma, ej: ceit_frro,otro_centro
INSTAGRAM_HANDLES=
NOVEDADES_MEDIA_DIR=/data/novedades_media

# --- Fuente: sitio web FRRO ---
UTN_NOVEDADES_URL=

# --- Scheduler (APScheduler in-process) ---
SCHEDULER_ENABLED=false
INGESTA_INSTAGRAM_HORAS=6
INGESTA_UTN_WEB_HORAS=24

# --- Observabilidad del clasificador (LangSmith, opcional) ---
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=utnhub
